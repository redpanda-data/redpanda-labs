{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inventory",
  "type": "object",
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Product SKU identifier"
    },
    "quantity": {
      "type": "integer",
      "description": "Available quantity in stock"
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds"
    }
  },
  "required": ["product_id", "quantity", "timestamp"]
}
